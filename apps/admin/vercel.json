{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 1 * * 0"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 1 1 * *"
    }
  ]
}
